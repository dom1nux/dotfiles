# Aliases
alias so="source ~/.zshrc"
alias cls="clear"
alias ls="eza --group-directories-first --icons=always"
alias ll="ls -la"
alias vi="nvim"
alias cz="chezmoi"
alias cza="chezmoi apply"
alias lg="lazygit"

# ── Interactive only ─────────────────────────────
[[ $- != *i* ]] && return

# Tools
eval "$(starship init zsh)"
fastfetch --logo small --logo-padding-left 0 --logo-padding-right 4 --structure Title:Separator:OS:Host:Uptime:Shell --separator " "
echo ""
