[user]
	email = go.francko.dr@gmail.com
	name = dom1nux
	signingkey = /home/dom1nux/.ssh/id_github_sign.pub
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = /home/dom1nux/.ssh/allowed_signers
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[alias]
	# status & info
	st = status -sb
	stu = status -sb -uall
	aliases = config --get-regexp ^alias\\.
	# branching
	co = checkout
	cob = checkout -b
	br = branch
	brd = branch -d
	brD = branch -D
	brr = branch -r
	bra = branch -a
	# staging & committing
	ci = commit
	cm = commit -m
	amend = commit --amend --no-edit
	amendne = commit --amend
	unstage = reset HEAD --
	stage = add
	all = add -A
	# diffs
	d = diff
	dc = diff --cached
	ds = diff --stat
	# logs
	l = log --oneline --decorate -20
	lg = log --oneline --decorate --graph -20
	lga = log --oneline --decorate --graph --all
	last = log -1 --stat
	# pulls & pushes
	pl = pull --rebase --autostash
	ps = push
	psf = push --force-with-lease
	# stashing
	stsh = stash push
	stp = stash pop
	stl = stash list
	# inspection
	remote = remote -v
	df = diff
	# plumbing shortcuts
	cp = cherry-pick
	rb = rebase
	rbi = rebase -i
	clean-branches = !git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d
